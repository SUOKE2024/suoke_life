# API 配置
API_URL=http://localhost:8080/api
AI_ENDPOINT=http://localhost:8081/ai

# 豆包 API 配置
DOUBAO_API_URL=http://localhost:8082/api
DOUBAO_API_KEY=your_dev_key
DOUBAO_AGENT_MODE=enabled
DOUBAO_HTTP2_ENABLED=true

# HTTP 配置
ENABLE_HTTP2=true
ALLOW_SELF_SIGNED=true
TIMEOUT=60

# AI Agent 配置
ENABLE_AGENT=true
AGENT_ENDPOINT=http://localhost:8083/agent
AGENT_MODE=development

# 日志配置
ENABLE_LOGGING=true
ENABLE_NETWORK_LOGGING=true 