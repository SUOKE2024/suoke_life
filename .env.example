# App Config
APP_NAME=SuoKe Life
APP_ENV=development
DEBUG=true

# API Config
API_URL=https://api.suoke.life
API_VERSION=v1
API_TIMEOUT=30000

# Database Config
DB_HOST=localhost
DB_PORT=3306
DB_NAME=suoke
DB_USER=root
DB_PASSWORD=

# AI Service Config
DOUBAO_API_KEY=your_api_key
DOUBAO_API_SECRET=your_api_secret
DOUBAO_PRO_32K_EP=https://api.doubao.com/v1/chat/pro_32k
DOUBAO_PRO_128K_EP=https://api.doubao.com/v1/chat/pro_128k
DOUBAO_EMBEDDING_EP=https://api.doubao.com/v1/embeddings

# Storage Config
STORAGE_PATH=/storage/emulated/0/SuoKe
CACHE_SIZE=100

# Other Config
LOG_LEVEL=debug
ENABLE_ANALYTICS=true