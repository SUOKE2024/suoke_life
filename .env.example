# 豆包 API 密钥（请替换为您的实际密钥）
DOUBAO_API_KEY=your_api_key_here

# 模型 ID（已配置默认值，可按需修改）
XIAOI_MODEL_ID=your_xiaoi_model_id
LAOKE_MODEL_ID=your_laoke_model_id
EMBEDDING_MODEL_ID=your_embedding_model_id

# 开发环境配置
ENV=development
DEBUG=true

# API 配置
API_BASE_URL=http://localhost:8000
API_VERSION=v1 

# 数据库配置
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=null

# 高德地图 API Keys
AMAP_IOS_KEY=your_ios_key_here
AMAP_ANDROID_KEY=your_android_key_here

# 其他配置
APP_NAME=索克生活
APP_ENV=development