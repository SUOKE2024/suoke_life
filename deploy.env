# 部署配置
REMOTE_HOST=118.31.223.213
REMOTE_USER=root
REMOTE_DIR=/opt/suoke_life

# App 配置
APP_NAME=SuoKe Life
APP_VERSION=1.0.0
APP_BUILD_NUMBER=1

# API 配置
API_BASE_URL=https://api.suoke.com
API_VERSION=v1
API_TIMEOUT=30000

# 数据库配置
DB_NAME=suoke.db
DB_VERSION=1
DB_ENCRYPTION=true

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 安全配置
ENCRYPTION_KEY=your_encryption_key_here
JWT_SECRET=your_jwt_secret_here

# 移动端配置
ANDROID_STORE_PASSWORD=***
ANDROID_KEY_PASSWORD=***
ANDROID_KEY_ALIAS=upload
ANDROID_PACKAGE_NAME=com.suoke.life
IOS_BUNDLE_ID=com.suoke.life
IOS_PROFILE_NAME=SuokeLife_Distribution
IOS_TEAM_ID=XXXXXXXXXX

# 第三方服务配置
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_API_KEY=your_api_key
FIREBASE_APP_ID=your_app_id
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# 环境配置
ENV=development
DEBUG=true
ENABLE_LOGGING=true

# 环境配置
ENVIRONMENT=production
API_URL=https://api.suoke.com 