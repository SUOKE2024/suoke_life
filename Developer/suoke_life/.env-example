# 索克生活微服务环境配置

# 阿里云容器镜像仓库配置
ALIYUN_USERNAME=netsong@sina.com
ALIYUN_PASSWORD=Netsong2025
ALIYUN_REGISTRY=registry.cn-hangzhou.aliyuncs.com
ALIYUN_NAMESPACE=suoke

# 服务器配置
DEV_SERVER=dev.suoke.life
PROD_SERVER=118.31.223.213
SSH_USER=root
SSH_KEY=/Users/songxu/.ssh/id_rsa

# 部署配置
VERSION=1.0.0
ENV=dev

# 数据库配置
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root_password
DB_NAME=suoke_db
DB_CHARSET=utf8mb4
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=3600

# Redis配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET=suoke_jwt_secret_key_2024
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# API网关配置
API_GATEWAY_PORT=8080
API_GATEWAY_READ_TIMEOUT=15s
API_GATEWAY_WRITE_TIMEOUT=15s
API_GATEWAY_MAX_HEADER_BYTES=1048576

# 认证服务配置
AUTH_SERVICE_PORT=8081
AUTH_SERVICE_HOST=auth-service

# 用户服务配置
USER_SERVICE_PORT=8082
USER_SERVICE_HOST=user-service

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout

# 监控配置
METRICS_ENABLED=true
TRACE_ENABLED=true

# 其他配置
TZ=Asia/Shanghai
GOPROXY=https://goproxy.cn,direct