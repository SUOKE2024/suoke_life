# 索克生活APP环境变量示例
# 复制此文件到.env并填入实际值

# 应用环境: development, test, production
APP_ENV=development

# 是否使用模拟数据
USE_MOCK_DATA=true

# API基础URL
API_BASE_URL=https://dev-api.suoke.life

# 百度文心一言API密钥
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# 阿里通义千问API密钥
ALI_API_KEY=
ALI_SECRET_KEY=

# 讯飞星火API密钥
XUNFEI_API_KEY=
XUNFEI_SECRET_KEY=

# 智谱ChatGLM API密钥
ZHIPU_API_KEY=
ZHIPU_SECRET_KEY=

# DeepSeek API密钥
DEEPSEEK_API_KEY=

# OpenAI API密钥
OPENAI_API_KEY=

# 是否启用OpenAI（需要国际网络）
ENABLE_OPENAI=false

# 服务配置
PORT=3007
CONFIG_PATH=config/config.json

# 安全配置
ENABLE_API_AUTH=false
API_KEY=suoke-life-default-key
RATE_LIMIT_ENABLED=true
MAX_REQUESTS_PER_MINUTE=100

# 日志配置
ENABLE_REQUEST_LOGGING=true
LOG_LEVEL=info

# Redis配置（可选）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 代理状态持久化
AGENT_STATE_PERSISTENCE=memory # memory, redis, file 