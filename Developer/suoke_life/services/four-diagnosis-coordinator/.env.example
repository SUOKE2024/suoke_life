# 服务配置
PORT=3050
NODE_ENV=development

# 日志配置
LOG_LEVEL=debug

# MongoDB数据库配置
MONGODB_URI=mongodb://localhost:27017/four-diagnosis-coordinator
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_AUTH_SOURCE=admin

# 关系型数据库配置（已废弃，使用MongoDB）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=four_diagnosis_coordinator
# DB_USER=postgres
# DB_PASSWORD=postgres

# API网关配置
API_GATEWAY_URL=http://localhost:3000

# 四诊服务配置
LOOKING_DIAGNOSIS_SERVICE_URL=http://localhost:3001
SMELL_DIAGNOSIS_SERVICE_URL=http://localhost:3005
INQUIRY_DIAGNOSIS_SERVICE_URL=http://localhost:3004
TOUCH_DIAGNOSIS_SERVICE_URL=http://localhost:3003

# AI服务配置
XIAOAI_SERVICE_URL=http://localhost:3100

# 缓存配置
CACHE_TTL=3600
DIAGNOSIS_CACHE_SIZE=1000

# 安全配置
JWT_SECRET=your_jwt_secret_key
TOKEN_EXPIRY=86400 