{
  "name": "agent-coordinator-service",
  "version": "1.2.0",
  "description": "索克生活APP AI代理协调器服务",
  "main": "src/index.js",
  "scripts": {
    "start": "node dist/src/index.js",
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "test": "jest",
    "test:coverage": "chmod +x ./scripts/test-coverage.sh && ./scripts/test-coverage.sh",
    "test:watch": "jest --watch",
    "test:ci": "jest --config test/ci/jest.config.ci.js --ci",
    "test:unit": "jest --testPathPattern='test/unit'",
    "test:integration": "jest --testPathPattern='test/integration'",
    "test:performance": "jest --testPathPattern='test/performance'",
    "test:e2e": "jest --testPathPattern='test/e2e'",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "benchmark": "cd test/benchmark && npm install && npm run benchmark",
    "benchmark:ci": "cd test/benchmark && npm install && npm run benchmark -- --config ci-config.json",
    "benchmark:baseline": "cd test/benchmark && npm install && npm run benchmark:baseline",
    "benchmark:schedule": "cd test/benchmark && chmod +x ./schedule-benchmark.sh && ./schedule-benchmark.sh",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "check-types": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepare": "husky install",
    "docker:build": "docker build -t agent-coordinator-service .",
    "docker:run": "docker run -p 4000:4000 agent-coordinator-service"
  },
  "keywords": [
    "agent-coordinator",
    "suoke",
    "microservices",
    "ai-agents"
  ],
  "author": "SuoKe Life Team",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.4",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "langchain": "^0.0.152",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^15.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/supertest": "^2.0.16",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^27.6.0",
    "eslint-plugin-prettier": "^5.0.1",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jsonwebtoken": "^9.0.2",
    "nodemon": "^3.0.1",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
