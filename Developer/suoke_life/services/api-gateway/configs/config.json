{
  "server": {
    "port": 8080,
    "host": "0.0.0.0",
    "read_timeout": 15,
    "write_timeout": 15,
    "shutdown_timeout": 10
  },
  "metrics": {
    "enabled": true,
    "path": "/metrics"
  },
  "cors": {
    "allowed_origins": ["*"],
    "allowed_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    "allowed_headers": ["Origin", "Content-Type", "Accept", "Authorization"],
    "allow_credentials": true,
    "max_age": 86400
  }
}