# 服务器配置
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
MAX_CONNECTIONS=100
REQUEST_TIMEOUT=30000
LOG_FORMAT=combined
LOG_DIR=logs

# 安全配置
CORS_ORIGIN=*
CORS_CREDENTIALS=false
CORS_MAX_AGE=86400
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
JWT_SECRET=suoke-life-api-gateway-dev-secret
JWT_EXPIRES_IN=1d
SALT_ROUNDS=10

# 健康检查配置
HEALTH_CHECK_INTERVAL=30000
ENABLE_METRICS=true
METRICS_INTERVAL=60000

# 微服务URL配置 - 开发环境
USER_SERVICE_URL=http://localhost:3001
AUTH_SERVICE_URL=http://localhost:3002
LAOKE_AGENT_SERVICE_URL=http://localhost:8080
HEALTH_ASSISTANT_AGENT_SERVICE_URL=http://localhost:8081
AGENT_COORDINATOR_SERVICE_URL=http://localhost:8082
FILE_SEARCH_SERVICE_URL=http://localhost:8083
WEB_SEARCH_SERVICE_URL=http://localhost:8084
HEALTH_SERVICE_URL=http://localhost:3003
LIFE_RECORD_SERVICE_URL=http://localhost:3004
KNOWLEDGE_GRAPH_SERVICE_URL=http://localhost:3005
MULTIMODAL_PROCESSOR_SERVICE_URL=http://localhost:3006
RAG_SERVICE_URL=http://localhost:3007
KNOWLEDGE_BASE_SERVICE_URL=http://localhost:3013
XIAOAI_SERVICE_URL=http://localhost:3014
XIAOKE_SERVICE_URL=http://localhost:3015
SOER_SERVICE_URL=http://localhost:3016

# 微服务超时配置（毫秒）
USER_SERVICE_TIMEOUT=5000
AUTH_SERVICE_TIMEOUT=5000
LAOKE_AGENT_SERVICE_TIMEOUT=30000
HEALTH_ASSISTANT_AGENT_SERVICE_TIMEOUT=30000
AGENT_COORDINATOR_SERVICE_TIMEOUT=30000
FILE_SEARCH_SERVICE_TIMEOUT=10000
WEB_SEARCH_SERVICE_TIMEOUT=15000
HEALTH_SERVICE_TIMEOUT=5000
LIFE_RECORD_SERVICE_TIMEOUT=5000
KNOWLEDGE_GRAPH_SERVICE_TIMEOUT=10000
MULTIMODAL_PROCESSOR_SERVICE_TIMEOUT=20000
RAG_SERVICE_TIMEOUT=15000
KNOWLEDGE_BASE_SERVICE_TIMEOUT=15000
XIAOAI_SERVICE_TIMEOUT=30000
XIAOKE_SERVICE_TIMEOUT=30000
SOER_SERVICE_TIMEOUT=30000

# 负载均衡策略
USER_SERVICE_LB_STRATEGY=round-robin
AUTH_SERVICE_LB_STRATEGY=round-robin
LAOKE_AGENT_SERVICE_LB_STRATEGY=round-robin
HEALTH_ASSISTANT_AGENT_SERVICE_LB_STRATEGY=round-robin
AGENT_COORDINATOR_SERVICE_LB_STRATEGY=round-robin
FILE_SEARCH_SERVICE_LB_STRATEGY=round-robin
WEB_SEARCH_SERVICE_LB_STRATEGY=round-robin
HEALTH_SERVICE_LB_STRATEGY=round-robin
LIFE_RECORD_SERVICE_LB_STRATEGY=round-robin
KNOWLEDGE_GRAPH_SERVICE_LB_STRATEGY=round-robin
KNOWLEDGE_BASE_SERVICE_LB_STRATEGY=round-robin
MULTIMODAL_PROCESSOR_SERVICE_LB_STRATEGY=round-robin
RAG_SERVICE_LB_STRATEGY=round-robin
XIAOAI_SERVICE_LB_STRATEGY=round-robin
XIAOKE_SERVICE_LB_STRATEGY=round-robin
SOER_SERVICE_LB_STRATEGY=round-robin

# 服务发现配置
SERVICE_DISCOVERY_ENABLED=true
SERVICE_DISCOVERY_ENDPOINT=http://service-registry:8080/discovery
SERVICE_REGISTRY_UPDATE_INTERVAL=60000