# 服务器配置
PORT=3002
APP_HOST=0.0.0.0
SERVER_READ_TIMEOUT=60
SERVER_WRITE_TIMEOUT=60
SERVER_IDLE_TIMEOUT=120
SERVER_MAX_HEADER_BYTES=1048576
APP_VERSION=1.0.0

# 数据库配置
DB_CONNECTION_STRING=postgresql://postgres:postgres@localhost:5432/knowledge_base?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_MAX_LIFETIME=300

# 向量存储配置
VECTOR_STORE_HOST=localhost
VECTOR_STORE_PORT=19530
VECTOR_STORE_COLLECTION=knowledge_base_documents
VECTOR_STORE_API_KEY=
VECTOR_STORE_USE_SSL=false
VECTOR_STORE_INDEX_TYPE=FLAT

# 嵌入服务配置
EMBEDDING_MODEL_URL=http://localhost:8000/embed
EMBEDDING_API_TOKEN=
EMBEDDING_CONTEXT_SIZE=4096
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=10

# 文本分割配置
TEXT_SPLITTER_CHUNK_SIZE=512
TEXT_SPLITTER_CHUNK_OVERLAP=128
TEXT_SPLITTER_SMART_BOUNDARY=true

# 安全配置
CORS_ORIGINS=*
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=86400

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_PATH=stdout
LOG_ERROR_PATH=stderr

# 监控配置
ENABLE_METRICS=true
METRICS_PORT=9090
OTEL_ENABLED=false
OTEL_SERVICE_NAME=knowledge-base-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.5

# 阿里云容器镜像仓库凭据
REGISTRY_URL=suoke-registry.cn-hangzhou.cr.aliyuncs.com/suoke/
REGISTRY_USERNAME=netsong@sina.com
REGISTRY_PASSWORD=Netsong2025 