# 服务基础配置
SERVICE_NAME=rag-service
VERSION=1.0.0
HOST=0.0.0.0
PORT=8080
DEBUG=false
ENVIRONMENT=production  # production, staging, development

# 进程配置
WORKERS=4  # 建议设置为CPU核心数
THREADS=2  # 每个worker的线程数
WORKER_CLASS=uvicorn.workers.UvicornWorker
TIMEOUT=120

# 日志配置
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_PATH=/var/log/rag-service
LOG_FORMAT=json  # json, text
LOG_ROTATION=1d  # 日志轮转周期
LOG_RETENTION=30d  # 日志保留时间
LOG_BACKUP_COUNT=30  # 保留的日志文件数量
LOG_ENCODING=utf-8
LOG_HANDLERS=["console", "file"]  # 日志处理器列表

# 监控配置
METRICS_PORT=9090
METRICS_PATH=/metrics
ENABLE_PROMETHEUS=true
ENABLE_TRACING=false
TRACING_SAMPLE_RATE=0.1

# Neo4j配置 (如果不使用Neo4j，可以删除此部分)
NEO4J_URI=bolt://neo4j-service:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-secure-password  # 生产环境请使用安全的密码管理方案
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=20
NEO4J_ENCRYPTION=true  # 启用加密以保护数据传输

# Redis配置
REDIS_HOST=redis-master
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your-redis-password  # 生产环境请使用安全的密码管理方案
REDIS_SSL=true  # 启用SSL以保护数据传输
REDIS_TIMEOUT=5
REDIS_POOL_SIZE=100
REDIS_MAX_RETRIES=3

# 缓存配置
CACHE_TYPE=redis  # redis, memory
CACHE_TTL=3600  # 缓存过期时间(秒)
CACHE_MAX_SIZE=10000  # 最大缓存条目数
CACHE_KEY_PREFIX=rag  # 缓存键前缀

# 向量存储配置
VECTOR_STORE_TYPE=milvus  # milvus, faiss
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=milvus
MILVUS_COLLECTION=rag_documents
VECTOR_DIMENSION=1024
VECTOR_METRIC_TYPE=IP  # IP, L2
VECTOR_NPROBE=10  # 搜索探针数
VECTOR_TOP_K=5  # 返回最相似的结果数
VECTOR_INDEX_TYPE=IVF_FLAT
VECTOR_INDEX_PARAMS={"nlist": 1024}
VECTOR_SEARCH_PARAMS={"nprobe": 10}

# LLM服务配置
LLM_SERVICE_URL=http://llm-service:8001
LLM_API_TYPE=openai
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key  # 生产环境请使用安全的密钥管理方案
LLM_API_MODEL=gpt-3.5-turbo
LLM_TIMEOUT=30
LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_MAX_RETRIES=3

# RAG配置
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_MAX_CHUNKS=5
RAG_MIN_RELEVANCE_SCORE=0.7
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
RAG_INCLUDE_METADATA=true
RAG_INCLUDE_SOURCES=true
RAG_USE_CACHE=true
RAG_CACHE_TTL=86400

# 嵌入模型配置
EMBEDDING_MODEL=bge-large-zh-v1.5
EMBEDDING_MODEL_PATH=/app/models
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32

# 安全配置
# API密钥认证
SECURITY_ENABLE_API_KEY_AUTH=true
SECURITY_API_KEYS_FILE=/app/config/api_keys.json

# 速率限制
SECURITY_ENABLE_RATE_LIMIT=true
SECURITY_MAX_REQUESTS_PER_MINUTE=60

# CORS设置
SECURITY_ENABLE_CORS=true
SECURITY_ALLOWED_ORIGINS=["https://api.suoke.life"]  # 限制允许的来源域名
SECURITY_ALLOW_CREDENTIALS=false

# 内容安全策略
SECURITY_ENABLE_CSP=true
SECURITY_CSP_POLICY="default-src 'self'; script-src 'self'; object-src 'none'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"

# JWT配置
SECURITY_JWT_SECRET=change_this_in_production_environment
SECURITY_JWT_EXPIRATION_MINUTES=60

# 管理员认证
SECURITY_ENABLE_ADMIN_AUTH=true
SECURITY_ADMIN_USERNAME=admin
SECURITY_ADMIN_PASSWORD_HASH=change_this_in_production_environment

# 数据安全
SECURITY_ENABLE_ENCRYPTION=false
SECURITY_ENCRYPTION_KEY=change_this_in_production_environment
SECURITY_ENABLE_PII_DETECTION=false

# 健康检查配置
HEALTH_CHECK_INTERVAL_SECONDS=30
HEALTH_CHECK_TIMEOUT_SECONDS=5
HEALTH_CHECK_RETRIES=3

# 性能优化配置
MAX_REQUEST_SIZE=50MB  # 最大请求大小
COMPRESSION_ENABLED=true  # 是否启用压缩
CONNECTION_TIMEOUT=10  # 连接超时时间(秒)
READ_TIMEOUT=30  # 读取超时时间(秒)
WRITE_TIMEOUT=30  # 写入超时时间(秒)
MAX_CONCURRENT_REQUESTS=1000  # 最大并发请求数
GRACEFUL_SHUTDOWN_TIMEOUT=30  # 优雅关闭超时时间(秒)

# 阿里云容器镜像仓库凭据
REGISTRY_URL=suoke-registry.cn-hangzhou.cr.aliyuncs.com/suoke/
REGISTRY_USERNAME=netsong@sina.com
REGISTRY_PASSWORD=Netsong2025 