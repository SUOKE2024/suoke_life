# 服务基础配置
SERVICE_NAME=rag-service
VERSION=1.0.0
HOST=0.0.0.0
PORT=8000
DEBUG=false
ENVIRONMENT=production  # production, staging, development

# 进程配置
WORKERS=4  # 建议设置为CPU核心数
THREADS=2  # 每个worker的线程数
WORKER_CLASS=uvicorn.workers.UvicornWorker
TIMEOUT=120

# 日志配置
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_PATH=/var/log/rag-service
LOG_FORMAT=json  # json, text
LOG_ROTATION=1d  # 日志轮转周期
LOG_RETENTION=30d  # 日志保留时间
LOG_BACKUP_COUNT=30  # 保留的日志文件数量
LOG_ENCODING=utf-8
LOG_HANDLERS=["console", "file"]  # 日志处理器列表

# 监控配置
METRICS_PORT=9090
METRICS_PATH=/metrics
ERROR_RATE_THRESHOLD=0.1  # 错误率阈值
LATENCY_THRESHOLD=5.0  # 延迟阈值(秒)
CACHE_HIT_RATE_THRESHOLD=0.7  # 缓存命中率阈值
ALERT_CHECK_INTERVAL=300  # 告警检查间隔(秒)
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus-metrics  # 多进程指标目录

# Neo4j配置
NEO4J_URI=bolt://neo4j-service:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-secure-password
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=20
NEO4J_MAX_TRANSACTION_RETRY_TIME=30
NEO4J_ENCRYPTION=true
NEO4J_TRUST=TRUST_SYSTEM_CA_SIGNED_CERTIFICATES

# Redis配置
REDIS_HOST=redis-master
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your-redis-password
REDIS_SSL=false
REDIS_TIMEOUT=5
REDIS_POOL_SIZE=100
REDIS_POOL_TIMEOUT=30
REDIS_RETRY_ON_TIMEOUT=true
REDIS_MAX_RETRIES=3
REDIS_ENCODING=utf-8

# 缓存配置
CACHE_TYPE=redis  # redis, memory
CACHE_TTL=3600  # 缓存过期时间(秒)
CACHE_MAX_SIZE=10000  # 最大缓存条目数
CACHE_KEY_PREFIX=rag  # 缓存键前缀
CACHE_SERIALIZER=json  # json, pickle
CACHE_COMPRESSION=true  # 是否启用压缩
CACHE_COMPRESSION_LEVEL=6  # 压缩级别(1-9)

# 向量存储配置
VECTOR_STORE_TYPE=milvus  # milvus, faiss
VECTOR_STORE_HOST=milvus-standalone
VECTOR_STORE_PORT=19530
VECTOR_DIMENSION=768
VECTOR_METRIC_TYPE=IP  # IP, L2
VECTOR_NPROBE=10  # 搜索探针数
VECTOR_TOP_K=5  # 返回最相似的结果数
VECTOR_INDEX_TYPE=IVF_FLAT
VECTOR_INDEX_PARAMS={"nlist": 1024}
VECTOR_SEARCH_PARAMS={"nprobe": 10}

# LLM服务配置
LLM_SERVICE_URL=http://llm-service:8001
LLM_API_KEY=your-api-key
LLM_TIMEOUT=30
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_FREQUENCY_PENALTY=0.0
LLM_PRESENCE_PENALTY=0.0
LLM_STOP_SEQUENCES=[]
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1

# RAG配置
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_MAX_CHUNKS=5
RAG_MIN_RELEVANCE_SCORE=0.7
RAG_RERANK_TOP_N=3
RAG_EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2
RAG_RERANKER_MODEL=cross-encoder/ms-marco-multilingual-MiniLM-L12-H384-v1
RAG_USE_CACHE=true
RAG_CACHE_TTL=86400

# 安全配置
JWT_SECRET_KEY=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=["https://api.suoke.life"]
RATE_LIMIT_REQUESTS=100  # 每个IP每分钟的请求限制
SSL_CERT_PATH=/etc/ssl/certs/api.suoke.life.crt
SSL_KEY_PATH=/etc/ssl/private/api.suoke.life.key
TRUSTED_HOSTS=["api.suoke.life"]
ALLOWED_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
ALLOWED_HEADERS=["*"]
MAX_HEADER_SIZE=8192
SECURE_HEADERS=true

# 阿里云配置
ALIYUN_REGION=cn-hangzhou
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
ACR_EE_REGISTRY=registry.cn-hangzhou.aliyuncs.com
ACR_EE_NAMESPACE=suoke
REGISTRY_USERNAME=your-registry-username
REGISTRY_PASSWORD=your-registry-password
ACK_CLUSTER_ID=your-cluster-id

# Kubernetes配置
K8S_NAMESPACE=suoke
K8S_SERVICE_ACCOUNT=rag-service
K8S_CONFIG_PATH=~/.kube/config
K8S_CONTEXT=your-cluster-context
K8S_RESOURCE_PREFIX=rag

# 健康检查配置
HEALTH_CHECK_INTERVAL=30  # 健康检查间隔(秒)
HEALTH_CHECK_TIMEOUT=5  # 健康检查超时时间(秒)
COMPONENT_CHECK_PARALLEL=true  # 是否并行检查组件健康状态
HEALTH_CHECK_RETRIES=3  # 健康检查重试次数
HEALTH_CHECK_INITIAL_DELAY=5  # 初始延迟时间(秒)
HEALTH_CHECK_ENDPOINTS=["/health", "/metrics"]

# 性能优化配置
MAX_REQUEST_SIZE=50MB  # 最大请求大小
COMPRESSION_ENABLED=true  # 是否启用压缩
COMPRESSION_LEVEL=6  # 压缩级别(1-9)
CONNECTION_TIMEOUT=10  # 连接超时时间(秒)
READ_TIMEOUT=30  # 读取超时时间(秒)
WRITE_TIMEOUT=30  # 写入超时时间(秒)
KEEP_ALIVE_TIMEOUT=5  # keep-alive超时时间(秒)
MAX_CONCURRENT_REQUESTS=1000  # 最大并发请求数
BACKLOG_SIZE=2048  # 等待连接队列大小
TCP_NODELAY=true  # 是否启用TCP_NODELAY
TCP_KEEPALIVE=true  # 是否启用TCP keepalive
GRACEFUL_SHUTDOWN_TIMEOUT=30  # 优雅关闭超时时间(秒)

# 其他配置
HEALTH_CHECK_INITIAL_DELAY=5  # 初始延迟时间(秒)
HEALTH_CHECK_ENDPOINTS=["/health", "/metrics"]
