{
  "name": "xiaoai-service",
  "version": "1.0.0",
  "description": "小艾智能体代理微服务 - 索克生活APP首页(聊天频道)版主，统筹四诊服务与无障碍功能",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "test": "jest --config tests/jest.config.js",
    "test:watch": "jest --config tests/jest.config.js --watch",
    "test:coverage": "jest --config tests/jest.config.js --coverage",
    "test:repositories": "jest --config tests/jest.config.js repositories",
    "test:services": "jest --config tests/jest.config.js services",
    "test:run": "bash scripts/run-tests.sh",
    "test:full": "bash scripts/run-tests.sh --all",
    "test:unit": "bash scripts/run-tests.sh --unit",
    "test:integration": "bash scripts/run-tests.sh --integration",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "install-dev-deps": "bash scripts/install-dev-deps.sh",
    "init-db": "ts-node src/scripts/initDatabase.ts"
  },
  "keywords": [
    "xiaoai",
    "agent",
    "accessibility",
    "voice-guidance",
    "tcm",
    "four-diagnosis"
  ],
  "author": "索克生活团队",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.40.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.45.0",
    "@opentelemetry/resources": "^1.18.1",
    "@opentelemetry/sdk-node": "^0.45.0",
    "@opentelemetry/sdk-trace-node": "^1.18.1",
    "@opentelemetry/semantic-conventions": "^1.18.1",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "joi": "^17.11.0",
    "mongoose": "^8.0.1",
    "winston": "^3.11.0",
    "openai": "^4.0.0",
    "prom-client": "^15.0.0",
    "socket.io": "^4.7.2",
    "redis": "^4.6.10",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}