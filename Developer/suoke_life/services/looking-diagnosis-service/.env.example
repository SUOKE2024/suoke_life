# 望诊服务环境变量示例配置

# 服务器配置
PORT=3011
HOST=0.0.0.0
NODE_ENV=development

# 日志配置
LOG_LEVEL=debug
LOG_FORMAT=combined

# 数据库配置
DB_HOST=localhost
DB_PORT=27017
DB_NAME=looking_diagnosis
DB_USER=suoke_app
DB_PASSWORD=your_secure_password

# API限制
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# 跨域配置
CORS_ORIGIN=*
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE

# 图像处理设置
MAX_IMAGE_SIZE=10 # 单位：MB
ALLOWED_IMAGE_TYPES=image/jpeg,image/png
IMAGE_QUALITY=90

# 舌诊AI模型配置
TONGUE_MODEL_PATH=./models/tongue-diagnosis-v1
AI_CONFIDENCE_THRESHOLD=0.65

# 微服务通信
FOUR_DIAGNOSIS_COORDINATOR_URL=http://localhost:3010/api/coordinator
USER_SERVICE_URL=http://user-service:3001
API_GATEWAY_URL=http://api-gateway:3000

# 分析结果持久化
STORE_IMAGES=true
IMAGE_STORAGE_PATH=./data/images
RESULT_STORAGE_PATH=./data/results

# 健康检查
HEALTH_CHECK_INTERVAL=60000 # 单位：毫秒

# 服务配置
API_PREFIX=/api

# 数据库配置
MONGODB_URI=mongodb://localhost:27017/looking-diagnosis
MONGODB_USER=
MONGODB_PASSWORD=

# 图像处理配置
TEMP_STORAGE_PATH=./data/temp

# 安全配置
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=24h

# AI模型配置
AI_MODELS_PATH=./models
FACE_MODEL_PATH=./models/face-diagnosis-v1

# 日志配置
LOG_DIR=./logs
MAX_LOG_SIZE=20m
MAX_LOG_FILES=14d 