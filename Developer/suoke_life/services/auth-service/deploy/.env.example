# 应用基本配置
APP_NAME=SuokeAuthService
APP_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
API_PREFIX=/api

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=suoke_auth

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET=your_jwt_secret_key
JWT_ACCESS_TOKEN_EXPIRATION=3600
JWT_REFRESH_TOKEN_EXPIRATION=2592000
JWT_ISSUER=suoke.life
JWT_AUDIENCE=suoke-app

# CSRF配置
CSRF_ENABLED=true
CSRF_EXPIRES_IN=3600
CSRF_SINGLE_USE=false
CSRF_EXCLUDE_PATHS=/api/auth/login,/api/auth/register,/api/auth/refresh,/api/auth/2fa/verify

# 刷新令牌配置
REFRESH_TOKEN_USE_COOKIE=true
REFRESH_TOKEN_ROTATE_ON_REFRESH=true
REFRESH_TOKEN_REUSE_DETECTION=true

# 账户锁定配置
ACCOUNT_LOCKOUT_ENABLED=true
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=300
ACCOUNT_LOCKOUT_COUNTER_RESET=600

# 密码策略配置
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true
PASSWORD_MAX_HISTORY=5
PASSWORD_EXPIRY_DAYS=90

# 短信验证配置
SMS_CODE_LENGTH=6
SMS_CODE_EXPIRY=300
SMS_SEND_INTERVAL=60
SMS_MAX_DAILY_SENDS=10
SMS_MAX_ATTEMPTS=5

# 短信服务配置
SMS_PROVIDER=aliyun
SMS_API_URL=https://dysmsapi.aliyuncs.com
SMS_ACCESS_KEY_ID=your_access_key_id
SMS_ACCESS_KEY_SECRET=your_access_key_secret
SMS_SIGN_NAME=索克生活
SMS_TEMPLATE_DEFAULT=SMS_123456789
SMS_TEMPLATE_LOGIN=SMS_123456781
SMS_TEMPLATE_REGISTER=SMS_123456782
SMS_TEMPLATE_RESET_PASSWORD=SMS_123456783
SMS_TEMPLATE_CHANGE_PHONE=SMS_123456784
SMS_TEMPLATE_VERIFY_PHONE=SMS_123456785
SMS_TEMPLATE_TWO_FACTOR=SMS_123456786

# 双因素认证配置
TOTP_ISSUER=索克生活
TOTP_SECRET_LENGTH=20
TOTP_WINDOW=1
RECOVERY_CODE_COUNT=10

# 安全日志配置
SECURITY_LOG_RETENTION_DAYS=30
SECURITY_LOG_MAX_USER_EVENTS=100

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIRECTORY=logs

# 性能监控
ENABLE_METRICS=true
METRICS_INTERVAL=15000

# 跨域配置
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE
CORS_ALLOWED_CREDENTIALS=true

# 服务健康检查
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000