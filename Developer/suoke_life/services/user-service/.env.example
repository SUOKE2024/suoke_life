# 索克生活用户服务 - 环境配置示例文件
# 复制此文件为.env并填入实际的值

# 服务配置
PORT=3002
NODE_ENV=development # development, test, production

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password # 留空表示无密码

# JWT配置
JWT_SECRET=your_jwt_secret_key # 生产环境请使用强随机值
JWT_EXPIRES_IN=24h # 令牌过期时间 例如: 60, "2 days", "10h", "7d"

# 外部服务URL
KNOWLEDGE_BASE_URL=http://knowledge-base-service-url
KNOWLEDGE_GRAPH_URL=http://knowledge-graph-service-url
USER_PROFILE_SERVICE=http://user-profile-service-url
SHARE_BASE_URL=http://share-base-url

# 日志配置
LOG_LEVEL=debug # debug, info, warn, error
LOG_PATH=./logs # 日志存储路径

# 模拟数据配置
USE_MOCK_DATA=false # true表示使用模拟数据
MOCK_API_DELAY=0 # 模拟API延迟毫秒数

# 文件上传配置
UPLOAD_DIR=./uploads # 文件上传目录
MAX_FILE_SIZE=5242880 # 最大文件大小(字节), 5MB

# 安全配置
AUDIT_LOG_ENABLED=true # 是否启用审计日志
STRUCTURED_LOGGING=true # 是否使用结构化日志
DATA_PRIVACY_ENABLED=true # 是否启用数据隐私保护

# 阿里云容器镜像仓库凭据
REGISTRY_USERNAME=your_registry_username
REGISTRY_PASSWORD=your_registry_password 