# 服务器配置
NODE_ENV=development
PORT=3007
HOST=localhost
SERVER_PROTOCOL=http

# 日志配置
LOG_LEVEL=info

# 数据库配置
DB_HOST=localhost
DB_PORT=27017
DB_NAME=inquiry_diagnosis
DB_USER=dbuser
DB_PASSWORD=dbpassword

# 安全配置
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=1d
CORS_ORIGIN=*
API_KEY=your_api_key_for_internal_services

# API文档配置
ENABLE_API_DOCS=true
API_DOCS_BASIC_AUTH=false
API_DOCS_USERNAME=admin
API_DOCS_PASSWORD=suoke2024

# 跨服务通信配置
XIAOAI_SERVICE_URL=http://localhost:3000
KNOWLEDGE_BASE_SERVICE_URL=http://localhost:3001
KNOWLEDGE_GRAPH_SERVICE_URL=http://localhost:3002
TCM_ANALYSIS_SERVICE_URL=http://localhost:3003
FOUR_DIAGNOSIS_COORDINATOR_URL=http://localhost:3004
HEALTH_PROFILE_SERVICE_URL=http://localhost:3005

# AI服务配置
AI_SERVICE_ENABLED=true
AI_SERVICE_URL=http://localhost:3006
AI_SERVICE_API_KEY=your_ai_service_api_key
LLM_SERVICE_URL=http://localhost:3008/api/llm
NLP_SERVICE_URL=http://localhost:3009/api/nlp

# 分布式追踪配置
TRACING_ENABLED=false
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6832

# 监控配置
MONITORING_ENABLED=false
PROMETHEUS_METRICS_PORT=9090

# 缓存配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 健康检查配置
HEALTH_CHECK_INTERVAL=30000

# 四诊协调服务配置
COORDINATOR_API_KEY=your_coordinator_api_key
COORDINATOR_WEBHOOK_URL=http://localhost:3007/api/coordinator/webhook

# 生产环境配置选项
