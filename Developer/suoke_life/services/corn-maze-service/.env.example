# 服务器配置
PORT=3001
NODE_ENV=development
API_PREFIX=/api/corn-maze

# 数据库配置
DB_URI=mongodb://localhost:27017/cornmaze
DB_USER=
DB_PASSWORD=

# JWT配置
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=86400

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=./logs/corn-maze-service.log

# 跨域配置
CORS_ORIGIN=*

# 其他服务地址
AR_SERVICE_URL=http://localhost:3002/api/ar
USER_SERVICE_URL=http://localhost:3003/api/users
LAOKE_SERVICE_URL=http://localhost:3005/api
KNOWLEDGE_GRAPH_SERVICE_URL=http://localhost:3006/api

# AR特性配置
AR_MARKER_EXPIRY_DAYS=30
LOCATION_SEARCH_RADIUS=50
AR_MESSAGE_DEFAULT_EXPIRY_HOURS=24
AR_IMAGE_STORAGE_PATH=./uploads/ar-images
AR_MODEL_STORAGE_PATH=./uploads/ar-models

# WebSocket配置
WS_PORT=3101
WS_PATH=/ws/corn-maze
WS_MAX_CONNECTIONS=500

# NPC系统配置
NPC_INTERACTION_COOLDOWN=10
NPC_DEFAULT_GREETING=欢迎来到索克玉米迷宫，我是老克！
