# 服务设置
PORT=3004
NODE_ENV=development
API_PREFIX=/api/touch-diagnosis
SERVICE_NAME=touch-diagnosis-service

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/touch-diagnosis-service.log

# MongoDB配置
MONGODB_URI=mongodb://localhost:27017/suoke_touch_diagnosis
MONGODB_USER=suoke_user
MONGODB_PASSWORD=password123
MONGODB_AUTH_SOURCE=admin
MONGODB_DB_NAME=suoke_touch_diagnosis

# API网关配置
GATEWAY_URL=http://localhost:3000
GATEWAY_API_KEY=your-gateway-api-key

# 四诊合参服务URL
FOUR_DIAGNOSIS_COORDINATOR_URL=http://localhost:3001/api/four-diagnosis

# 其他相关服务配置
PATIENT_SERVICE_URL=http://localhost:3005/api/patients
TCM_KNOWLEDGE_SERVICE_URL=http://localhost:3006/api/tcm-knowledge

# 缓存配置
CACHE_TTL=3600
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# 安全配置
JWT_SECRET=your-jwt-secret-key
ACCESS_TOKEN_EXPIRY=1h
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# 分析引擎配置
MAX_ANALYSIS_TIMEOUT_MS=30000
ANALYSIS_BATCH_SIZE=10
ENABLE_ADVANCED_ANALYSIS=true 