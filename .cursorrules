        - lib/data/repositories
        - lib/di
        - lib/services
        - lib/presentation
        - test
        - assets
      files:
        - lib/di/register_module.dart
        - lib/services/multimodal_processing_service.dart
        - lib/app.dart
        - lib/main.dart
        - Dockerfile
        - pubspec.yaml
