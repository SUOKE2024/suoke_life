{"name":"SuoKe Life Development Guide","version":"1.0.0","description":"Development standards and guidelines for SuoKe Life project","language_settings":{"default":"en","available":["en","zh"],"files":{"en":".cursorrules.en","zh":".cursorrules.zh"}}, "ios": { "dependencies": { "source": { "primary": "https://github.com/CocoaPods/Specs.git", "mirrors": [ "https://mirrors.tuna.tsinghua.edu.cn/git/CocoaPods/Specs.git", "https://mirrors.cloud.tencent.com/CocoaPods/Specs.git", "https://mirrors.aliyun.com/cocoapods/Specs.git" ] }, "fallback_strategy": { "retry_count": 3, "timeout": 300, "mirror_rotation": true }, "cache": { "clean_on_failure": true, "preserve_important": [ "Flutter", "Flutter.framework", "Generated.xcconfig" ] } }, "pod_install": { "pre_actions": [ "flutter clean", "flutter pub get", "rm -rf Pods/", "rm -rf Podfile.lock" ], "post_actions": [ "pod repo update", "pod install --repo-update" ] } } }
