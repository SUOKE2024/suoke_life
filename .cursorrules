      - test/core/services/chat_service_test.dart
      - test/core/services/expert_service_test.dart
      - test/core/services/health_service_test.dart
      - test/core/services/payment_service_test.dart
      - test/core/services/notification_service_test.dart
      - test/core/services/analytics_service_test.dart
      - test/core/services/data_sync_service_test.dart
      - test/features/home/pages/chat_page_test.dart
  integration_test:
    path: integration_test/
  code_coverage:
    enabled: true
    report_path: coverage/lcov.info
  tooling:
    enforce_rule_checking: true # 强制执行规则检查
    tool: flutter_lints # 推荐使用的规则检查工具 (例如 flutter_lints)

# Agentic AI Rules: 定义智能代理相关的规则和配置
agentic_ai:
  - name: Xiaoai
    description: Health management AI agent. # Xiaoai 是健康管理 AI 代理
    module: lib/services/xiaoai_service.dart
    tools:
      - health_data_api:
          description: API for accessing user health data. # 用于访问用户健康数据的 API
          endpoints:
            - /v1/users/{userId}/health_data
            - /v1/health_records
      - health_knowledge_base:
          type: vector_database # 健康知识库类型为向量数据库
          source: curated_medical_database # 数据来源为精选的医疗数据库
          retrieval_strategy: semantic_search # 检索策略为语义搜索
      - reminder_tool # 提醒工具
    memory:
      type: sqflite # 内存类型为 SQLite (本地存储)
      path: lib/data/local/xiaoai_memory.db # 内存存储路径
      strategy: conversational_history_and_profile # 记忆策略：对话历史和用户画像
      retention_policy:
        conversational_history: 7d # 对话历史保留 7 天
        user_profile: persistent # 用户画像持久存储
      data_types: # 内存中存储的数据类型
        - conversation_turns # 对话轮次
        - user_preferences # 用户偏好
    planning:
      - collect_health_data:
          description: Retrieve user's latest health metrics. # 检索用户最新的健康指标
      - analyze_health_data:
          description: "Analyze health data to identify trends and potential issues." # 分析健康数据以识别趋势和潜在问题
          steps:
            - extract_key_metrics # 提取关键指标
            - compare_with_historical_data # 与历史数据对比
            - identify_potential_risks # 识别潜在风险
            - provide_health_advice # 提供健康建议
            - remind_user_to_take_medicine # 提醒用户按时服药
    datasets:
      health_metrics:
        source: user_health_data_api # 数据来源：用户健康数据 API
        type: time_series # 数据类型：时间序列
        access_permission: read # 访问权限：只读
      medical_knowledge:
        source: curated_medical_database # 数据来源：精选的医疗数据库
        type: knowledge_graph # 数据类型：知识图谱
        access_permission: read # 访问权限：只读
    collaboration: # 协作配置
      strategy: cooperative # 协作策略为合作
      allowed_agents: # 允许协作的 Agent 列表
        - Xiaoke
        - Laoke
      communication_protocol: shared_memory # 通信协议为共享内存
      description: "Xiaoai Agent 可以与 Xiaoke 和 Laoke Agent 协作，通过共享内存方式进行高效通信，协同完成健康管理任务。" # 描述
  - name: Xiaoke
    description: Life record AI agent. # Xiaoke 是生活记录 AI 代理
    module: lib/services/xiaoke_service.dart
    tools:
      - calendar_api # 日历 API
      - task_management_api # 任务管理 API
      - life_knowledge_base:
          type: document_store # 生活知识库类型为文档存储
          source: user_provided_notes, public_knowledge_base # 数据来源：用户提供的笔记和公共知识库
          retrieval_strategy: keyword_search # 检索策略为关键词搜索
      - product_order_api # 产品订单 API
      - production_plan_api # 生产计划 API
      - user_experience_api # 用户体验 API
      - marketing_promotion_api # 营销推广 API
    memory:
      type: sqflite # 内存类型为 SQLite (本地存储)
      path: lib/data/local/xiaoke_memory.db # 内存存储路径
      strategy: task_and_activity_history # 记忆策略：任务和活动历史
      retention_policy:
      type: sqflite # 内存类型为 SQLite
      path: lib/data/local/xiaoke_memory.db # 内存存储路径
    planning:
      - record_user_daily_activities # 记录用户日常活动
      - analyze_user_activities # 分析用户活动
      - remind_user_to_complete_tasks # 提醒用户完成任务
      - provide_life_advice # 提供生活建议
      - manage_product_orders # 管理产品订单
      - manage_production_plans # 管理生产计划
      - improve_user_experience # 提升用户体验
      - manage_marketing_promotions # 管理营销推广
    datasets:
      life_activities:
        source: user_activity_logs # 数据来源：用户活动日志
        type: structured # 数据类型：结构化数据
        access_permission: read # 访问权限：只读
      task_information:
        source: task_management_system # 数据来源：任务管理系统
        type: structured # 数据类型：结构化数据
        access_permission: read # 访问权限：只读
    collaboration: # 协作配置
      strategy: orchestration # 协作策略为编排
      allowed_agents: # 允许协作的 Agent 列表
        - Xiaoai
      communication_protocol: api_call # 通信协议为 API 调用
      description: "Xiaoke Agent 可以与 Xiaoai 和 Xiaoke Agent 协作，通过 API 调用方式进行通信，实现更复杂的功能。" # 描述
  - name: Laoke
    description: Knowledge question and answer AI agent. # Laoke 是知识问答 AI 代理
    module: lib/services/laoke_service.dart
    tools:
      - search_engine_api # 搜索引擎 API
      - knowledge_graph_api:
          type: knowledge_graph # 知识图谱 API 类型为知识图谱
          source: wikipedia, wikidata # 数据来源：维基百科和维基数据
          retrieval_strategy: graph_traversal # 检索策略为图遍历
      - database_query_tool # 数据库查询工具
      - game_management_api # 游戏管理 API
    memory:
      type: sqflite # 内存类型为 SQLite (本地存储)
      path: lib/data/local/laoke_memory.db # 内存存储路径
      strategy: question_answer_history # 记忆策略：问答历史
      retention_policy:
        question_answer_history: 30d # 问答历史保留 30 天
      data_types: # 内存中存储的数据类型
        - questions # 用户问题
        - answers # 系统答案
    planning:
      - receive_user_questions # 接收用户提问
      - analyze_user_questions # 分析用户提问
      - query_knowledge_base # 查询知识库
      - return_answers # 返回答案
      - manage_game_data # 管理游戏数据
    datasets:
      general_knowledge:
        source: public_knowledge_graph # 数据来源：公共知识图谱
        type: knowledge_graph # 数据类型：知识图谱
        access_permission: read # 访问权限：只读
    collaboration: # 协作配置
      strategy: delegation # 协作策略为委托
      allowed_agents: # 允许协作的 Agent 列表
        - Xiaoai
        - Xiaoke
      communication_protocol: message_queue # 通信协议为消息队列
      description: "Laoke Agent 可以将任务委托给 Xiaoai 和 Xiaoke Agent 处理，通过消息队列方式进行异步通信。" # 描述

# Training data configuration: 定义模型训练数据相关的配置
training_data:
  llm_training:
    dataset_name: large_text_corpus # LLM 训练数据集名称
    source: common_crawl, bookcorpus # 数据来源
    size: "TB scale" # 数据集大小
    preprocessing:
      - tokenization # 分词
      - cleaning # 清洗
    optimization: # 模型优化配置
      fine_tuning: # 微调配置
        enabled: true # 默认启用微调
      compression: # 模型压缩配置
        enabled: true # 默认启用压缩
        techniques: # 压缩技术
          - pruning # 剪枝
      evaluation_metrics: # 评估指标
        - perplexity # 困惑度
    update_frequency: monthly # 更新频率：每月
  multimodal_training:
    dataset_name: image_text_pairs # 多模态训练数据集名称
    source: image_caption_datasets # 数据来源
    size: "Millions of samples" # 数据集大小
    preprocessing:
      - image_resizing # 图片缩放
      - text_cleaning # 文本清洗
    update_frequency: quarterly # 更新频率：每季度
  agent_specific_training: # 特定 Agent 的训练数据
    Xiaoai:
      dataset_name: anonymized_health_records # 数据集名称：匿名化健康记录
      source: internal_data # 数据来源：内部数据
      size: "100K records" # 数据集大小
      preprocessing:
        - anonymization # 匿名化
        - feature_engineering # 特征工程
      optimization: # 模型优化配置
        fine_tuning: # 微调配置
          enabled: true # 默认启用微调
          parameters: # 微调参数 (示例)
            - learning_rate: 0.0001
        compression: # 模型压缩配置
          enabled: false # 默认不启用压缩
        evaluation_metrics: # 评估指标
          - f1_score # F1 值
      update_frequency: bi-annually # 更新频率：每半年
    Xiaoke:
      dataset_name: anonymized_life_records # 数据集名称：匿名化生活记录
      source: internal_data # 数据来源：内部数据
      size: "50K records" # 数据集大小
      preprocessing:
        - anonymization # 匿名化
        - feature_engineering # 特征工程
      optimization: # 模型优化配置
        fine_tuning: # 微调配置
          enabled: false # 默认不启用微调
        compression: # 模型压缩配置
          enabled: false # 默认不启用压缩
        distillation: # 模型蒸馏配置
          enabled: true # 默认启用蒸馏
          teacher_model: large_laoke_model # 教师模型 (示例)
        evaluation_metrics: # 评估指标
          - bleu_score # BLEU 值
      update_frequency: quarterly # 更新频率：每季度
    Laoke:
      dataset_name: question_answer_pairs # 数据集名称：问答对
      source: curated_qna_datasets # 数据来源：精选的问答数据集
      size: "1M pairs" # 数据集大小
      preprocessing:
        - text_cleaning # 文本清洗
        - question_normalization # 问题标准化
      optimization: # 模型优化配置
        fine_tuning: # 微调配置
          enabled: false # 默认不启用微调
        compression: # 模型压缩配置
          enabled: false # 默认不启用压缩
        distillation: # 模型蒸馏配置
          enabled: true # 默认启用蒸馏
          teacher_model: large_laoke_model # 教师模型 (示例)
        evaluation_metrics: # 评估指标
          - bleu_score # BLEU 值
      update_frequency: bi-annually # 更新频率：每半年

# Database Configuration: 定义数据库连接配置
database:
  remote:
    relational: # 关系型数据库
      type: mysql # 远程关系型数据库类型为 MySQL
      host: 118.31.223.213 # 数据库主机地址
      port: 3306 # 数据库端口
      user: suoke # 数据库用户名
      database: suoke_health # 数据库名
      description: "适用于存储结构化数据，例如用户信息、健康记录、生活记录、知识库等。"
    nosql: # NoSQL 数据库
      type: redis
      description: "适用于存储非结构化数据、缓存数据、实现消息队列等功能，支持实时数据分析。"

# AI Agent Integration: 定义 AI 代理集成相关的配置
ai_integration:
  multi_model: true # 是否使用多模型
  gui_interaction:
    enabled: true # 是否启用 GUI 交互
    technology: aria_ui # GUI 交互技术为 Aria UI
  voice_interaction:
    enabled: true # 是否启用语音交互
    technology: transformer # 语音交互技术为 Transformer
  realtime_interaction:
    enabled: true # 是否启用实时交互
    technology: rte # 实时交互技术为 RTE
  model_selection:
    strategy: dynamic # 模型选择策略为动态选择
    criteria: service_context # 模型选择标准为服务上下文
  rag_configuration: # RAG 相关配置
    knowledge_base: # 知识库配置
      type: knowledge_graph # 知识库类型：知识图谱
      source: wikipedia, curated_data # 知识库数据来源：维基百科，精选数据
      integration:
        - health_profile # 集成健康画像
      reasoning:
        - graph_traversal # 图遍历推理
        - rule_based_reasoning # 基于规则的推理
      recommendation:
        - knowledge_graph_based_recommendation # 基于知识图谱的推荐
        - personalized_recommendation # 个性化推荐
      indexing_strategy: semantic # 知识库索引策略：语义索引
      update_frequency: monthly # 知识库更新频率：每月
      embedding_model: openai/text-embedding-ada-002 # Embedding 模型：OpenAI Ada-002 (示例)
    retrieval: # 检索配置
      strategy: hybrid_retrieval # 检索策略：混合检索 (关键词 + 语义)
      top_k: 10 # Top K 检索结果数量：10
      knowledge_sources: # 知识来源
        - local_knowledge_base # 本地知识库
        - web_search # 网络搜索
      web_search_configuration: # 网络搜索配置
        enabled: true # 启用网络搜索
        api_provider: google_custom_search # 网络搜索 API 提供商：Google Custom Search (示例)
        api_key_secret_management: secure_storage # API 密钥管理：安全存储
      score_threshold: 0.7 # 相关性得分阈值：0.7
      chunking_strategy: semantic_chunking # 文本分块策略：语义分块
    generation: # 生成配置
      context_window_size: 4096 # 上下文窗口大小
      prompt_strategy: standard_rag # Prompt 策略：标准 RAG, 可选值: standard_rag, query_expansion, context_compression, re_ranking, chain_of_thought_rag
      prompt_strategy_options: # Prompt 策略选项 (用于配置不同策略的参数)
        query_expansion: # 查询扩展策略
          expansion_model: "..." # 查询扩展模型 (示例)
        context_compression: # 上下文压缩策略配置
          compression_ratio: 0.5 # 压缩率 (示例)
          compression_method: "keywords" # 压缩方法 (示例): keywords, summary, reorder_filter
          keywords_num: 10 # 关键词提取数量 (示例)
          summary_model_name: "bart-large-cnn" # 摘要模型名称 (示例)
        re_ranking: # 重排序策略配置
          re_ranking_model_name: "sentence-transformers/all-mpnet-base-v2" # 重排序模型名称 (示例)
          similarity_metric: "cosine" # 相似度度量指标 (示例): cosine, dot_product
          top_n: 5 # 重排序后保留 Top N 个结果 (示例)
        chain_of_thought_rag: # Chain-of-Thought RAG 策略配置
          cot_prompt_template: "请一步步思考，并给出最终答案。" # CoT Prompt 模板 (示例)
          few_shot_examples_path: "assets/data/cot_examples.json" # Few-shot 示例文件路径 (示例)
      knowledge_fusion_method: weighted_average # 知识融合方法为加权平均
      response_parameters: # 响应生成参数
        temperature: 0.7 # Temperature：0.7
        top_p: 0.9 # Top P：0.9
        max_tokens: 512 # 最大 Token 数：512
    evaluation: # 评估与监控配置
      metrics: # 评估指标
        - context_relevance
        - answer_faithfulness
        - answer_relevance
        - latency
      logging_enabled: true # 启用 RAG 日志记录：是
  model_composition: # 模型组合配置
    patterns: # 支持的模型组合模式
      - sequential # 串行模式
      - parallel # 并行模式
      - ensemble # 集成模式
      - hierarchical # 分层模式
    orchestration_framework: airflow # 模型编排框架：Airflow (示例)
    service_mesh: istio # 服务网格：Istio (示例)

# Test rules: 定义测试相关的规则
test:
  mocks:
    path: test/mocks # Mock 对象存放路径
    naming: mock_*.dart # Mock 对象命名规范
  matchers:
    prefer_type_matchers: true # 优先使用类型匹配器
    use_meaningful_descriptions: true # 使用有意义的描述
  structure:
    group_by_feature: true # 测试用例按功能模块分组
    follow_arrange_act_assert: true # 遵循 Arrange-Act-Assert 测试模式

# Adaptation & Internationalization Rules: 定义系统自适应与国际化相关的规则 (简化版)
adaptation_i18n:
  localization:
    enabled: true # 启用国际化 (Localization)
    default_locale: zh_CN # 默认语言 (中文)
    supported_locales: # 支持的语言列表
      - zh_CN # 简体中文
      - en_US # 英语 (美国)
    locale_file_path: assets/locales # 语言文件存放路径
    locale_file_pattern: "{locale}.json" # 语言文件命名模式，例如 en_US.json, zh_CN.json
    auto_detect_system_locale: true # 自动检测系统语言
    on_install_set_locale: true # 安装时设置为系统语言 (如果支持)
    description: "APP 启动时自动检测用户系统语言，并设置为应用语言 (如果支持)。如果系统语言不在支持列表中，则使用默认语言。"
  regional_settings: # 区域设置 (简化，可根据需要扩展)
    date_format: system_default # 日期格式：跟随系统默认
    time_format: system_default # 时间格式：跟随系统默认
    number_format: system_default # 数字格式：跟随系统默认
    currency_format: system_default # 货币格式：跟随系统默认
    timezone: system_default # 时区：跟随系统默认
    description: "区域设置 (日期、时间、数字、货币、时区) 默认跟随用户系统设置。"

Fangyan_mode_api: # FangyanModeAPI - 方言模型 API (新名称)
  description: "FangyanModeAPI is a generic, open-source **API service** providing a large dialect model for dialect recognition and adaptation. It emphasizes user privacy by storing user-specific metadata locally and supporting background contribution of **anonymized** voice data to a central training set via API. Designed for integration with any AI agent or application requiring robust dialect support." # FangyanModeAPI 是一个通用的开源 **API 服务**，提供用于方言识别和适配的大型方言模型。它强调用户隐私，通过本地存储用户特定元数据，并支持通过 API 在后台将 **匿名化** 的语音数据贡献到中央训练集。旨在与任何需要强大方言支持的 AI 代理或应用程序集成。(**更新描述，使用新名称 FangyanModeAPI**)
  personalization_api: # 方言个性化 API (名称同步更新)
    description: **API for** personalizing local language understanding using FangyanModeAPI. It features real-time adaptation, optional client-managed contextual prompts, and background contribution of **anonymized** data. Agent-agnostic and designed for API integration, with user metadata stored locally. # **用于** 使用 FangyanModeAPI 个性化本地语言理解的 **API**。它具有实时适配、可选的客户端管理上下文提示和后台 **匿名化** 数据贡献功能。与 Agent 无关，专为 API 集成而设计，用户元数据本地存储。(**更新描述，使用新名称 FangyanModeAPI**)
    method: api_driven_dialect_personalization # 适配方法：API 驱动的方言个性化
    trigger_condition: on_api_request # 触发条件：API 请求时
    data_input: voice_data_via_api # 数据输入：通过 API 传输的语音数据
    prompt_message: "Optional prompt message can be managed by the client application." # 提示信息：提示信息变为可选，由客户端应用管理
    adaptation_strategy: server_side_online_learning_and_aggregation # 适配策略：服务器端在线学习和聚合
    model_type: large_dialect_model_api # 模型类型：大型方言模型 API
    feature_sharing: cross_client_and_fangyan_mode_api # 特征共享：跨客户端和 FangyanModeAPI (名称同步更新)
    data_storage: fangyan_mode_api_shared_repository # 数据存储：FangyanModeAPI 共享仓库 (名称同步更新)
    metadata_storage: local_device_storage # 元数据存储：本地设备存储
    privacy_policy: "Voice data is processed via API for dialect recognition. User-specific metadata is stored locally. Anonymized data contribution to FangyanModeAPI training set is optional and requires user consent. See data usage agreement for details." # 隐私政策：通过 API 处理语音数据以进行方言识别。用户特定元数据本地存储。匿名数据贡献是可选的，需要用户同意。详细信息请参阅数据使用协议。(**更新隐私政策，使用新名称 FangyanModeAPI**)
    contribution_guidelines_url: "https://fangyan-mode-api.org/contribution-guidelines" # 贡献指南 URL (域名示例，已更新为 fangyan-mode-api.org)
    community_forum_url: "https://fangyan-mode-api.org/forum" # 社区论坛 URL (域名示例，已更新为 fangyan-mode-api.org)
  data_contribution_api: # 数据贡献 API 配置 (名称同步更新)
    enabled: true # 启用数据贡献
    api_endpoint: "https://fangyan-mode-api.org/api/v1/data_contribution" # 数据贡献 API 端点 (域名示例，已更新为 fangyan-mode-api.org)
    anonymization_method: voice_feature_extraction_and_tokenization # 匿名化方法：语音特征提取和 Token 化
    data_types: # 贡献的数据类型
      - voice_features_via_api # 通过 API 传输的语音特征
      - optional_dialect_labels # 可选的方言标签
    trigger_condition: client_initiated_api_call # 触发条件：客户端发起的 API 调用
    upload_frequency: client_controlled # 上传频率：客户端控制
    data_size_limit: client_defined # 数据大小限制：客户端定义
    network_condition: client_preference # 网络条件：客户端偏好
    user_consent_required: true # 是否需要用户同意：是
    consent_prompt_message: "FangyanModeAPI can be improved by contributing your **anonymized** dialect data. Do you consent to contribute?" # 用户同意提示信息 (使用新名称 FangyanModeAPI)
    data_usage_agreement_url: "https://fangyan-mode-api.org/data_usage_agreement" # 数据使用协议 URL (域名示例，已更新为 fangyan-mode-api.org)

multimodal: # 多模态配置
  enabled: true # 启用多模态
  input_modalities: # 支持的输入模态
    - image
    - voice
    - video
  processing_methods: # 多模态处理方法
    - feature_extraction # 特征提取
    - modality_fusion # 模态融合

data_flow: # 数据流描述
  user_interaction: # 用户交互
    modalities: # 支持的模态
      - text
      - voice
      - image
      - video
      - file
    description: "用户通过多种模态与 AI 代理进行自然交互。"
  local_data_storage: # 本地数据存储
    database: sqflite # 数据库类型：sqflite
    purpose: "存储用户隐私数据，包括对话历史、健康数据、偏好设置等。"
    encryption: true # 数据加密：启用
    anonymization: false # 匿名化：否 (本地存储不匿名化)
  rag_process: # RAG 流程
    knowledge_sources: # 知识来源
      - knowledge_graph_api # 知识图谱 API (远程)
      - health_profile_api # 健康画像 API (本地/远程)
      - local_database # 本地数据库 (sqflite)
    description: "RAG 流程从多知识源检索信息，增强上下文，并生成多模态回复。"
  data_contribution: # 数据贡献
    purpose: "用于模型训练和知识图谱强化。"
    anonymization: true # 匿名化：是 (上传前匿名化)
    - voice_features_via_api # 通过 API 传输的语音特征
    - optional_dialect_labels # 可选的方言标签
    trigger_condition: client_initiated_api_call # 触发条件：客户端发起的 API 调用

# Navigation rules for RAG strategies
nav_rules:
  - path: lib/core/services/rag/
    cursor_positions:
      - context_compression_strategy.dart:
        - "abstract class ContextCompressionStrategy"
      - re_ranking_strategy.dart:
        - "abstract class ReRankingStrategy"
      - no_re_ranking_strategy.dart:
        - "class NoReRankingStrategy implements ReRankingStrategy"
      - semantic_similarity_re_ranking_strategy.dart:
        - "class SemanticSimilarityReRankingStrategy implements ReRankingStrategy"
      - no_compression_strategy.dart:
        - "class NoCompressionStrategy implements ContextCompressionStrategy"
