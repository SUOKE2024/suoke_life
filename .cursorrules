      path: apps/llm_service/
      sub_dirs:
        - lib
        - lib/data
        - lib/data/models
        - lib/data/repositories
        - lib/di
        - lib/services
        - lib/presentation
        - test
        - assets
      files:
        - lib/di/register_module.dart
        - lib/services/llm_service.dart
        - lib/app.dart
        - lib/main.dart
        - Dockerfile
        - pubspec.yaml
  libs:
    - name: core
      path: libs/core/
      sub_dirs:
