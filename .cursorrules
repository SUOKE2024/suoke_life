Cursor Rules Configuration
version: 1.0

# Project structure rules: 定义项目的基本目录结构和所需文件
structure:
  root_dirs:
    - lib: # Dart 代码主要存放目录
        sub_dirs:
          - core: # 核心库
            sub_dirs:
              - config # 配置
              - database # 数据库
              - di # 依赖注入
              - di/modules # 依赖注入模块
              - network # 网络
              - theme # 主题
              - utils # 工具类
              - models # 数据模型
              - repositories # 数据仓库
              - router # 路由
              - services # 服务
              - services/user # 用户服务
              - services/health # 健康服务
              - services/life # 生活服务
              - ui_components: # UI 组件库
                sub_dirs:
                  - buttons # 按钮组件
                  - cards # 卡片组件
                  - dialogs # 对话框组件
                  - navigation # 导航组件
                  - styles # 样式
                  - navigation # 导航
          - features: # 功能模块 (features 目录本身也应该在 root_dirs 中)
            sub_dirs:
              - home
              - suoke
              - explore
              - life
              - profile
              - auth
          - apps: # 应用模块 (apps 目录本身也应该在 root_dirs 中)
            sub_dirs:
              - ai_assistant_service
              - health_service
              - life_service
              - user_service
              - multimodal_service
              - llm_service
    - test: # 单元测试和集成测试代码存放目录
        sub_dirs: # 更详细的子目录结构
          - features: # 功能模块测试
            sub_dirs:
              - home
              - suoke
              - explore
              - life
              - profile
              - auth
              - ui_components # ui 组件测试
          - core: # 核心库测试
            sub_dirs:
              - services # core 下的 services 目录测试
              - models # core 下的 models 目录测试
    - docs # 项目文档存放目录
    - assets # 静态资源文件存放目录 (例如图片、字体)
    - scripts # 脚本文件存放目录 (例如部署脚本、代码生成脚本)
  required_files:
    - README.md # 项目的说明文档
    - pubspec.yaml # Flutter 项目的配置文件，包含依赖和项目信息
    - analysis_options.yaml # Dart 代码静态分析的配置文件
    - .gitignore # Git 版本控制的忽略配置文件
    - CHANGELOG.md # 记录版本更新日志
    - LICENSE # 项目开源许可证
  ignored_dirs:
    - build # Flutter 构建产物输出目录
    - .dart_tool # Dart 工具生成的临时文件目录
    - .idea # IntelliJ IDEA IDE 的项目配置文件目录
    - .vscode # VS Code IDE 的项目配置文件目录
    - coverage # 代码覆盖率报告目录

# Code style rules: 定义 Dart 和 Flutter 代码的风格规范
style:
  dart:
    line_length: 120 # Dart 代码行的最大长度
    prefer_single_quotes: true # 优先使用单引号
    always_specify_types: true # 总是指定类型, 强制类型声明
    directives_ordering: true # import 语句排序
    sort_constructors_first: true # 类构造函数排序
    parameter_assignments: false # 避免在方法体内赋值参数
    unnecessary_this: false # 避免不必要的 this
    prefer_final_locals: true # 偏向 final 局部变量
    avoid_empty_else: true # 避免空的 else 分支
  flutter:
    always_declare_return_types: true # 总是声明函数返回类型
    prefer_const_constructors: true # 优先使用 const 构造函数
    avoid_print: true # 避免使用 print 语句

# Documentation rules: 定义项目文档的要求
docs:
  required:
    - README.md # 必须包含 README.md 文件
    - CHANGELOG.md # 必须包含 CHANGELOG.md 文件，记录版本更新
    - LICENSE # 必须包含 LICENSE 文件，声明项目许可
  recommended:
    - CONTRIBUTING.md # 推荐包含 CONTRIBUTING.md 文件，说明如何贡献代码
    - CODE_OF_CONDUCT.md # 推荐包含 CODE_OF_CONDUCT.md 文件，定义行为准则
  code_comments: # 代码注释规范
    format: dart_doc # 代码注释格式：Dart doc (/// 或 /** ... */)
    content_requirements: # 注释内容要求
      - function_purpose # 描述函数/方法的功能和用途
      - parameter_meaning # 描述参数的含义和用途 (@param)
      - return_value_meaning # 描述返回值的类型和含义 (@return)
      - exception_handling # 描述可能抛出的异常情况 (@throws 或 @exception)
      - code_example # 在必要时提供代码示例
    enforcement: required # 强制执行代码注释规范
    description: "强制使用 Dart doc 格式 (/// 或 /** ... */) 编写代码注释，并清晰描述函数/方法的功能、参数、返回值和异常情况。" # 描述
    required_for: # 需要添加注释的元素
      - function # 函数/方法
      - class # 类

# Security rules: 定义项目的安全相关配置
security:
  env_files:
    - .env.example # 环境变量文件的示例
  secrets:
    - .env # 敏感环境变量文件，不应提交到版本控制
    - google-services.json # Firebase Android 配置文件
    - GoogleService-Info.plist # Firebase iOS 配置文件
  dependency_check: true # 依赖包安全检查
  dependency_check_tool: flutter_pub_audit # 依赖包安全检查工具：flutter pub audit
  api_requests_use_https: true # API 请求使用 HTTPS
  data_transmission_encryption: true # 数据传输加密 (TLS/SSL)

# Privacy rules: 定义用户隐私数据处理的相关规则
privacy:
  user_data_classification:
    - personal_information: # 个人信息
      - name
      - email
      - phone_number
      - address
    - health_data: # 健康数据
      - heart_rate
      - sleep_patterns
      - medical_records
    - life_activity_data: # 生活活动数据
      - daily_activities
      - location_history
      - task_completion
    - device_info: # 设备信息
      - device_model
      - os_version
      - device_id
    - behavior_data: # 行为数据
      - page_views
  data_handling_policy:
    encryption_at_rest: true # 静态数据加密
    encryption_in_transit: true # 传输中数据加密
    data_access_control: role_based_access_control # 数据访问控制
    anonymization_methods: # 匿名化方法
      - user_id: sha256_hash
      - location: city_level
    data_retention_period: # 数据保留期限
      personal_information: 365d
      health_data: 730d
      life_activity_data: 365d
    consent_management: required # 用户同意管理
    third_party_data_sharing:
      allowed: false # 是否允许与第三方共享数据
      justification_required: true # 如果允许，需要提供理由
      approved_third_parties: [] # 允许共享数据的第三方列表
  local_data_storage: # 本地数据存储策略
    database: sqflite # 本地数据库类型：sqflite
    encryption: true # 本地数据加密：启用
    data_types: # 本地存储的数据类型
      - conversation_history # 对话历史 (文本、语音、图像等)
      - user_health_data # 用户健康数据
      - user_preferences # 用户偏好设置
      - agent_memory # Agent 记忆数据
      - app_local_data # 应用本地数据
    anonymization_at_rest: false # 静态数据匿名化：否 (本地存储不匿名化)
    data_retention_policy: # 本地数据保留策略
      configurable_by_user: true # 用户可配置：是
      default_retention_period: 30d # 默认保留期限：30 天
      options: # 保留期限选项
        - 7d # 7 天
        - 30d # 30 天
        - 90d # 90 天
        - persistent # 永久保留
    access_control: # 本地数据访问控制
      policy: device_owner_access_only # 仅设备所有者可访问
  data_contribution: # 数据贡献策略
    enabled_by_default: false # 默认不启用数据贡献
    user_consent_required: true # 需要用户同意：是
    anonymization_before_upload: true # 上传前匿名化：是
    anonymization_methods: # 匿名化方法
      - personal_info_removal # 移除个人身份标识信息
      - user_id_hashing # 用户 ID 哈希
      - voice_feature_extraction # 语音特征提取 (而非原始语音)
      - image_feature_extraction # 图像特征提取 (而非原始图像)
    data_types_for_contribution: # 用于贡献的数据类型 (匿名化后)
      - anonymized_conversation_data # 匿名化对话数据

# Service Layer Rules: 定义服务层的架构和实现规范
services:
  architecture: layered # 采用分层架构
  pattern: repository # 使用 Repository 模式
  dependency_injection: # 依赖注入配置
    framework: get_it # 使用 get_it 作为依赖注入框架，替换 injectable
    description: "使用 get_it 进行依赖注入管理，提供轻量级、易于使用的服务定位器模式。" # 更新描述
    modules: # 依赖注入模块
      - storage_module: lib/core/di/modules/storage_module.dart # 存储模块
      - network_module: lib/core/di/modules/network_module.dart # 网络模块
      # ... 其他模块 ...
    registration_strategy: module_functions # 使用模块函数进行注册，替代 injectable 的模块类
    registration_example: | # 注册示例，展示如何使用 get_it 注册依赖
      // lib/di/modules/service_module.dart
      import 'package:get_it/get_it.dart';
      import 'package:my_app/services/my_service.dart';

      void registerServiceModule(GetIt getIt) {
        getIt.registerLazySingleton(() => MyService());
      }

      // lib/di/injection.dart
      import 'package:get_it/get_it.dart';
      import 'modules/service_module.dart';

      final getIt = GetIt.instance;

      void configureDependencies() {
        registerServiceModule(getIt);
        // ... 注册其他模块 ...
      }
  cache_strategy: multi_level # 采用多级缓存策略
  storage:
    local:
      type: sqflite # 本地数据库使用 sqflite
      encryption: true # 本地存储数据加密
      strategy: conversational_history_and_profile # 记忆策略：对话历史和用户画像
      retention_policy:
        conversational_history: 7d # 对话历史保留 7 天
        user_profile: persistent # 用户画像持久存储
      data_types: # 内存中存储的数据类型
        - conversation_turns # 对话轮次
        - user_preferences # 用户偏好
      usage:
        - user_privacy_data # 用户隐私数据
        - agent_memory # Agent 记忆数据
        - app_local_data # 应用本地数据
      performance:
        optimization: indexing # 数据库性能优化：索引
      description: "用于存储用户隐私数据和应用运行所需的本地数据。"
    local_key_value: # 新增：本地键值存储
      type: shared_preferences
      description: "用于存储少量配置信息、用户偏好设置等。"
    remote:
      type: redis # 远程存储使用 Redis
      replication: true # Redis 启用复制
      description: "用于缓存热点数据，支持会话管理和实时数据分析。"
    object_storage: # 新增：对象存储
      type: oss # 使用阿里云 OSS
      provider: aliyun
      description: "用于存储大量的非结构化数据，例如用户上传的图片、视频等。"
  security:
    encryption: aes_256 # 数据加密算法使用 AES-256
    key_management: secure_storage # 密钥管理使用安全存储
    data_masking: required # 需要进行数据脱敏
  sync:
    strategy: incremental # 数据同步策略为增量同步
    priority: high # 数据同步优先级高
    offline_support: true # 支持离线操作
    conflict_resolution: last_write_wins # 冲突解决策略为最后写入者胜出
  cache:
    levels:
      - memory # 一级缓存：内存
      - sqflite # 二级缓存：SQLite (适用于移动端)
      - redis # 三级缓存：Redis (适用于服务器端和部分移动端热点数据)
    policy: lru # 缓存淘汰策略为 LRU (Least Recently Used)
    ttl: enabled # 启用缓存 TTL (Time To Live)
    preload: true # 预加载缓存数据
    description: "合理利用 Redis 缓存热点数据，减轻数据库压力，提高应用性能。"
  session_management: # 新增：会话管理
    strategy: redis # 使用 Redis 存储会话信息
    ttl: 3600 # 会话过期时间 (秒)
    description: "使用 Redis 存储用户会话信息，提高会话管理的效率和可扩展性。"
  network:
    retry: true # 网络请求失败后重试
    timeout: 5s # 网络请求超时时间为 5 秒
    interceptors:
      - auth # 身份验证拦截器
      - cache # 缓存拦截器
      - encryption # 加密拦截器
      - retry # 重试拦截器
    api_version: v1 # API 版本号
    rate_limiting:
      enabled: true # 启用 API 速率限制
      requests_per_minute: 100 # 每分钟允许的请求数
      limiting_dimension: user_id # 速率限制维度：用户 ID
      strategy: token_bucket # 速率限制策略：令牌桶
      exceed_action: reject # 超出速率限制后的操作：拒绝请求
  cache:
    levels:
      - memory # 一级缓存：内存
      - sqflite # 二级缓存：SQLite (适用于移动端)
      - redis # 三级缓存：Redis (适用于服务器端和部分移动端热点数据)
    policy: lru # 缓存淘汰策略为 LRU (Least Recently Used)
    ttl: enabled # 启用缓存 TTL (Time To Live)
    preload: true # 预加载缓存数据
    description: "合理利用 Redis 缓存热点数据，减轻数据库压力，提高应用性能。"
  session_management: # 新增：会话管理
    strategy: redis # 使用 Redis 存储会话信息
    ttl: 3600 # 会话过期时间 (秒)
    description: "使用 Redis 存储用户会话信息，提高会话管理的效率和可扩展性。"
  network:
    retry: true # 网络请求失败后重试
    timeout: 5s # 网络请求超时时间为 5 秒
    interceptors:
      - auth # 身份验证拦截器
      - cache # 缓存拦截器
      - encryption # 加密拦截器
      - retry # 重试拦截器
    api_version: v1 # API 版本号
    rate_limiting:
      enabled: true # 启用 API 速率限制
      requests_per_minute: 100 # 每分钟允许的请求数
      limiting_dimension: user_id # 速率限制维度：用户 ID
      strategy: token_bucket # 速率限制策略：令牌桶
      exceed_action: reject # 超出速率限制后的操作：拒绝请求

# Analytics Rules: 定义数据分析相关的规则
analytics:
  data_collection:
    local_data:
      behavior_tracking: required # 必须进行用户行为追踪
      performance_monitoring: required # 必须进行性能监控
      error_logging: required # 必须进行错误日志记录
    anonymization:
      collected_data_types: # 具体收集的数据类型
        - page_views # 页面浏览量
        - button_clicks # 按钮点击量
      user_id: sha256_hash # 用户 ID 匿名化使用 SHA256 哈希
      location: city_level # 位置信息匿名化到城市级别
      device_info: platform_only # 设备信息仅收集平台信息
    retention:
      raw_data: 30d # 原始数据保留 30 天
      anonymized_data: 365d # 匿名化数据保留 365 天
      aggregated_data: unlimited # 聚合数据无限期保留
    processing:
      anonymization:
        required: true # 数据处理前必须进行匿名化
        rules:
          - personal_info_removal # 移除个人信息
          - id_hashing # ID 哈希
          - location_generalization # 位置信息泛化
      aggregation:
        min_group_size: 10 # 聚合数据的最小组大小为 10
        time_window: 24h # 聚合的时间窗口为 24 小时
      metrics:
        - usage_patterns # 使用模式
        - performance_stats # 性能统计
        - error_rates # 错误率
    data_sampling:
      enabled: true # 启用数据采样
      sample_rate: 0.1 # 采样率为 0.1
    data_validation:
      enabled: true # 启用数据验证
      rules:
        - type_check # 类型检查
        - range_check # 范围检查
    usage:
      allowed:
        - system_optimization # 允许用于系统优化
        - knowledge_enhancement # 允许用于知识增强
        - feature_improvement # 允许用于功能改进
      prohibited:
        - user_identification # 禁止用于用户识别
        - personal_tracking # 禁止用于个人追踪
        - data_sharing # 禁止数据共享

# APP Directory Structure: 定义 APP 模块的目录结构
app_structure:
  root: suoke_life/
